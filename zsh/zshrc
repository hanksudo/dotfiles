# --- zinit bootstrap ---
ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"
if [[ ! -d "$ZINIT_HOME" ]]; then
    mkdir -p "$(dirname $ZINIT_HOME)"
    git clone https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME"
fi
source "${ZINIT_HOME}/zinit.zsh"

# --- Completion system ---
autoload -Uz compinit && compinit
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'

# --- History ---
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt SHARE_HISTORY
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE
setopt HIST_REDUCE_BLANKS
setopt AUTO_CD

# --- OMZ plugins (loaded as snippets, no full OMZ clone needed) ---
zinit snippet OMZL::key-bindings.zsh
zinit snippet OMZP::aws
zinit snippet OMZP::nmap
zinit snippet OMZP::npm
zinit snippet OMZP::python
zinit snippet OMZP::rust
zinit snippet OMZP::docker

# --- Third-party plugins (lazy loaded for fast startup) ---
zinit ice wait lucid atload"_zsh_autosuggest_start"
zinit light zsh-users/zsh-autosuggestions

zinit ice wait lucid
zinit light zsh-users/zsh-syntax-highlighting

# --- Starship prompt ---
eval "$(starship init zsh)"

# --- Paths ---
export PATH=/usr/local/bin:/usr/local/sbin:$PATH
export PATH="$HOME/bin:$PATH"

# Added Go paths
if type go > /dev/null; then
    export GOPATH=`go env GOPATH`  # default is $HOME/go
    export GOROOT=`go env GOROOT`
    export PATH=$PATH:$GOPATH/bin
fi

# zmv '(*).html $1.haml'
# http://zshwiki.org/home/builtin/functions/zmv
autoload -U zmv

# default editor
export EDITOR=vim

# npm speed up npm on node-gyp
export JOBS=max

#autojump - https://github.com/joelthelion/autojump
# A cd command that learns - easily navigate directories from the command line
[[ -s `brew --prefix`/etc/autojump.sh ]] && . `brew --prefix`/etc/autojump.sh

# extra functions, aliases
source ~/.functions
source ~/.aliases

# Magnificent app which corrects your previous console command.
# https://github.com/nvbn/thefuck
eval $(thefuck --alias)

# A command-line fuzzy finder written in Go
# https://github.com/junegunn/fzf
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

# scmpuff makes working with git from the command line quicker by substituting numeric shortcuts for filenames
# https://mroth.github.io/scmpuff/
eval "$(scmpuff init -s)"

# google cloud sdk
source "/opt/homebrew/Caskroom/google-cloud-sdk/latest/google-cloud-sdk/path.zsh.inc"
source "/opt/homebrew/Caskroom/google-cloud-sdk/latest/google-cloud-sdk/completion.zsh.inc"

# fnm - https://github.com/Schniz/fnm
eval "$(fnm env --use-on-cd)"

. ~/.zprofile
